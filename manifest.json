{
  "manifest_version": 3,
  "name": "Smart Productivity & Analytics Extension",
  "version": "1.0",
  "description": "Track your productivity and active time on all websites.",
  "permissions": [
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}